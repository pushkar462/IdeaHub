DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ideahub?schema=public"
JWT_SECRET="super-secret-key"
PORT=4000
GROQ_API_KEY="gsk_your_key_here"

# Comma-separated list of allowed frontend origins, e.g. https://your-app.vercel.app
# Leave empty for local dev only — production must set this explicitly.
CORS_ORIGIN=""

# File storage: "local" (dev default) or "supabase" (required once deployed to Render, no persistent disk)
STORAGE_PROVIDER="local"
SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_STORAGE_BUCKET="uploads"

